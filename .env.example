# Supabase - get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is used only on the server (cron + admin routes).
# Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to authenticate the nightly stats cron job
CRON_SECRET=generate-a-long-random-string

# Optional override for the NHL API base URL
NHL_API_BASE=https://api-web.nhle.com/v1

# Optional: lock the "Refresh NHL data" button (and the underlying
# /api/admin/reseed endpoint) to a single user. Set this to the exact
# email address you signed up to the pool with, case-insensitive. If
# left unset, ANY signed-in user can refresh — fine for first-time
# setup but probably not what you want once friends join.
APP_OWNER_EMAIL=
