# Supabase - get these from your project's API settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key is used only on the server (cron + admin routes).
# Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret used to authenticate the nightly results cron job.
CRON_SECRET=generate-a-long-random-string

# API-Football (api-sports.io) - free tier, 100 req/day, covers the
# 2026 World Cup with fixtures, events (goalscorers) and top scorers.
# Get a key at https://www.api-football.com/  (or the RapidAPI listing).
API_FOOTBALL_KEY=your-api-football-key
API_FOOTBALL_BASE=https://v3.football.api-sports.io
# The API-Football league id for the FIFA World Cup competition.
API_FOOTBALL_WC_LEAGUE_ID=1
# Season year for the 2026 edition.
API_FOOTBALL_WC_SEASON=2026

# Optional: lock commissioner-only admin endpoints to a single user.
# Set to the exact email you signed up with (case-insensitive). If unset,
# any signed-in member can run them - fine for setup, not for game day.
APP_OWNER_EMAIL=

# Web Push (VAPID) keys for match / goal push notifications. Generate a
# pair with:  npx web-push generate-vapid-keys
# If either is unset, push silently no-ops and we fall back to in-tab only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@example.com
